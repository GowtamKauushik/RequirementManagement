          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"mobile\": \"1234567890\",\n  \"email\": \"contact@acme.com\",\n  \"address\": \"123 Main St\",\n  \"assignedUserId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/customers",
              "host": ["{{baseUrl}}"],
              "path": ["customers"]
            }
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp Updated\",\n  \"mobile\": \"1234567890\",\n  \"email\": \"contact@acme.com\",\n  \"address\": \"123 Main St\",\n  \"assignedUserId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/customers/1",
              "host": ["{{baseUrl}}"],
              "path": ["customers", "1"]
            }
          }
        },
        {
          "name": "Delete Customer",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/customers/1",
              "host": ["{{baseUrl}}"],
              "path": ["customers", "1"]
            }
          }
        }
      ]
    },
